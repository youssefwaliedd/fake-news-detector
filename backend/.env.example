# --- LLM (Groq is 100% free, no credit card) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# --- Web search for evidence retrieval ---
# Option A: Tavily free tier (1,000 searches/mo) — https://app.tavily.com
TAVILY_API_KEY=
# Option B: keyless/unlimited DuckDuckGo — set SEARCH_PROVIDER=ddgs and leave Tavily blank
SEARCH_PROVIDER=tavily

# --- Optional tuning (defaults shown) ---
# ML_WEIGHT=0.4
# FAKE_THRESHOLD=0.60
# REAL_THRESHOLD=0.40
# MAX_CLAIMS=5
# RESULTS_PER_CLAIM=3

# --- Server ---
CORS_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO
